{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore(release):${component} ${version}",
  "include-component-in-tag": true,
  "tag-separator": "/",
  "label": "status:release-pending",
  "release-label": "status:release-tagged",
  "changelog-sections": [
    {"type": "feat", "section": "Features"},
    {"type": "fix", "section": "Bug Fixes"},
    {"type": "perf", "section": "Performance"},
    {"type": "refactor", "section": "Refactoring"},
    {"type": "chore", "section": "Miscellaneous", "hidden": true},
    {"type": "docs", "section": "Documentation", "hidden": true},
    {"type": "test", "section": "Tests", "hidden": true},
    {"type": "ci", "section": "CI", "hidden": true},
    {"type": "build", "section": "Build", "hidden": true}
  ],
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "c12n-poly",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "exclude-paths": ["core", "go", "py", "rs", "ts", "php"],
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "go": {
      "release-type": "go",
      "component": "c12n",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "core": {
      "release-type": "rust",
      "component": "c12n-core",
      "package-name": "hop-top-c12n-core",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "rs": {
      "release-type": "rust",
      "component": "c12n-rs",
      "package-name": "hop-top-c12n",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "py": {
      "release-type": "python",
      "component": "c12n-py",
      "package-name": "hop-top-c12n",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "toml",
          "path": "py/pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ],
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "ts": {
      "release-type": "node",
      "component": "c12n-ts",
      "package-name": "@hop-top/c12n",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "json",
          "path": "ts/package.json",
          "jsonpath": "$.version"
        }
      ],
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    },
    "php": {
      "release-type": "php",
      "component": "c12n-php",
      "package-name": "hop-top/c12n",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "json",
          "path": "php/composer.json",
          "jsonpath": "$.version"
        }
      ],
      "prerelease": true,
      "prerelease-type": "alpha.0",
      "versioning": "prerelease",
      "initial-version": "0.1.0-alpha.0"
    }
  }
}
