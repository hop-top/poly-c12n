{
  "name": "@hop-top/c12n",
  "version": "0.0.0-alpha.1",
  "description": "TypeScript bindings for c12n-core — classification pipeline via WebAssembly",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nodejs": {
      "types": "./dist/nodejs.d.ts",
      "import": "./dist/nodejs.js",
      "require": "./dist/nodejs.cjs"
    }
  },
  "scripts": {
    "build:wasm:bundler": "wasm-pack build ../core --target bundler --out-dir ../ts/pkg/bundler -- --features wasm --no-default-features",
    "build:wasm:nodejs": "wasm-pack build ../core --target nodejs --out-dir ../ts/pkg/nodejs -- --features wasm --no-default-features",
    "build:wasm:test": "wasm-pack build ../core --target nodejs --out-dir ../ts/pkg/nodejs -- --features wasm --no-default-features",
    "build:ts": "tsc --build",
    "build": "pnpm build:wasm:bundler && pnpm build:wasm:nodejs && pnpm build:ts",
    "test": "vitest run --exclude test/bundler-smoke.test.ts",
    "test:unit": "vitest run test/pipeline.test.ts",
    "test:integration": "pnpm build:wasm:test && vitest run test/pipeline.integration.test.ts",
    "test:bundler": "pnpm build:wasm:bundler && vitest run --config vitest.browser.config.ts",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix"
  },
  "dependencies": {
    "@hop-top/kit": "^0.5.0-alpha"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/browser": "^1",
    "eslint": "^10.2.0",
    "playwright": "^1.44.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^1"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "pkg",
    "README.md",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hop-top/c12n.git",
    "directory": "c12n-ts"
  },
  "keywords": [
    "classification",
    "wasm",
    "c12n",
    "hop-top",
    "signal",
    "pipeline"
  ]
}
